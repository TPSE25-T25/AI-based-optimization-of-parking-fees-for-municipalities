# ---- Backend ----
# Comma-separated list of allowed CORS origins (include your Azure URL)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost,https://<your-app>.azurewebsites.net

# Database URL (defaults to local SQLite)
# DATABASE_URL=sqlite:///backend/services/database/app.db

# ---- Frontend (used at BUILD time only) ----
# Leave empty for production (relative URLs proxied by nginx)
VITE_API_BASE_URL=

# For local development without Docker, set to backend URL:
# VITE_API_BASE_URL=http://localhost:6173
